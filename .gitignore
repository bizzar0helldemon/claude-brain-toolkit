# Personal content — excluded by default to prevent accidental publishing
# Remove these lines if you're using a private repo and want to track your content
daily_notes/*.md
intake/sessions/*.md
intake/discoveries/*.md
people/*.md
IDENTITY.md

# Vault template directories (scaffolding — not part of the toolkit)
portfolio/
archive/

# Keep template/index files tracked
!projects/_INDEX.md
!creative/_INDEX.md
!intake/_INDEX.md
!prompts/_INDEX.md

# Internal development planning (GSD phase plans, research, state)
.planning/

# Personal dev skills (not part of the toolkit distribution)
.claude/skills/

# Local dev overrides (never ship to users)
CLAUDE.local.md

# Project-local brain context — holds personal IDs (Linear team UUIDs, etc.)
# Users should copy .brain.md.example to .brain.md and fill in their own values
.brain.md

# Python venv (created by user for vector search support)
.venv/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
