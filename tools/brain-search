#!/usr/bin/env bash
# Wrapper: runs brain-search.py using the toolkit's venv if available, else system python3.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_PYTHON="${SCRIPT_DIR}/../.venv/bin/python3"

if [ -x "$VENV_PYTHON" ]; then
  exec "$VENV_PYTHON" "${SCRIPT_DIR}/brain-search.py" "$@"
else
  exec python3 "${SCRIPT_DIR}/brain-search.py" "$@"
fi
